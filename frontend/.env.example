# URL base de la API. En desarrollo se usa el proxy de Vite (/api).
VITE_API_URL=/api

# Debe coincidir con API_KEY del backend. Se incrusta en el bundle JS en
# build time: frena abuso automatizado/anónimo directo a la API, pero no
# es secreta frente a quien inspeccione el código fuente del navegador.
VITE_API_KEY=
