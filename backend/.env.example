# Servidor API
NODE_ENV=development
PORT=3002
# Dejar vacío en producción si el frontend llega por el mismo origen
# (proxy nginx). Solo listar orígenes explícitos separados por coma si
# hay un frontend en otro dominio.
CORS_ORIGIN=http://localhost:5173
# Obligatoria en producción (el servidor no arranca sin ella si
# NODE_ENV=production). El frontend debe enviarla como header X-API-Key
# (ver VITE_API_KEY en frontend/.env.example). Generar con:
# openssl rand -hex 32
API_KEY=

# SQL Server
# IMPORTANTE: usar un login de SOLO LECTURA dedicado (NUNCA "sa" ni un
# usuario con roles de sysadmin/db_owner). Ver backend/sql/create_readonly_user.sql
# para crear un login con permiso SELECT únicamente sobre las vistas AV_*
# que necesita el dashboard y el asistente IA.
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=NombreBaseDatos
DB_USER=usuario_solo_lectura
DB_PASSWORD=contraseña
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Asistente IA (opencode.ai / Anthropic compatible)
AI_API_KEY=tu-api-key
AI_BASE_URL=https://opencode.ai/zen/go/v1
AI_MODEL=minimax-m3
